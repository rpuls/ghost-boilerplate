  "nx": {
    "tags": [
      "i18n"
    ],
    "targets": {
      "build:tsc": {
        "dependsOn": [
          "^build"
        ]
      },
      "archive": {
        "dependsOn": [
          "build:assets",
          "build:tsc",
          {
            "projects": [
              "@tryghost/admin"
            ],
            "target": "build"
          }
        ]
      },
      "dev": {
        "dependsOn": [
          "build:assets"
        ]
      },
      "lint": {
        "dependsOn": [
          "^build"
        ]
      },
      "test:all": {
        "dependsOn": [
          "build:assets"
        ]
      },
      "test:unit": {
        "dependsOn": [
          "build:assets",
          "^build"
        ]
      },
      "test:ci:e2e": {
        "dependsOn": [
          "^build"
        ],
        "outputs": [
          "{projectRoot}/coverage-e2e"
        ]
      },
      "test:ci:e2e:no-coverage": {
        "dependsOn": [
          "^build"
        ]
      },
      "test:ci:legacy": {
        "dependsOn": [
          "^build"
        ]
      },
      "test:ci:integration": {
        "dependsOn": [
          "^build"
        ],
        "outputs": [
          "{projectRoot}/coverage-integration"
        ]
      },
      "test:ci:integration:no-coverage": {
        "dependsOn": [
          "^build"
        ]
      }
    }
  },
